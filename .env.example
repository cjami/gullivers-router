# HuggingFace token for gated repos (Gemma, EmbeddingGemma).
HF_TOKEN=

# Shared Fireworks key; used by any role whose provider is `fireworks`
# unless overridden by a role-specific `<ROLE>_API_KEY`.
FIREWORKS_API_KEY=

# Hackathon proxy override; when set, Fireworks roles use this instead of role-specific URLs.
FIREWORKS_BASE_URL=

# Harness-injected allowlist (comma-separated). When set, the cloud model is picked from it by
# family preference and used verbatim, overriding CLOUD_MODEL. Leave unset for local development.
ALLOWED_MODELS=

# Local generation model (llama.cpp, auto-downloaded from HuggingFace).
LOCAL_PROVIDER=llama
LOCAL_REPO_ID=google/gemma-4-E2B-it-qat-q4_0-gguf
LOCAL_FILENAME=gemma-4-E2B_q4_0-it.gguf
LOCAL_N_CTX=2048
LOCAL_N_GPU_LAYERS=-1
LOCAL_FLASH_ATTN=true
LOCAL_ENABLE_THINKING=true
LOCAL_TEMPERATURE=1.0
LOCAL_TOP_P=0.95
LOCAL_TOP_K=64
LOCAL_N_THREADS=
LOCAL_MODEL_ROOT=models

# Embedding model (llama.cpp).
EMBEDDING_PROVIDER=llama
EMBEDDING_REPO_ID=ggml-org/embeddinggemma-300M-GGUF
EMBEDDING_FILENAME=*Q8_0.gguf
EMBEDDING_N_CTX=2048
EMBEDDING_N_GPU_LAYERS=-1
EMBEDDING_N_THREADS=
EMBEDDING_MODEL_ROOT=models

# Runtime cloud model (OpenAI-compatible Fireworks endpoint).
CLOUD_PROVIDER=fireworks
CLOUD_MODEL=accounts/fireworks/models/minimax-m3
CLOUD_BASE_URL=https://api.fireworks.ai/inference/v1
CLOUD_TIMEOUT_SECONDS=

# Training judge model (GLM 5.2 on Fireworks; batch inference).
JUDGE_PROVIDER=fireworks
JUDGE_MODEL=accounts/fireworks/models/glm-5p2
JUDGE_BASE_URL=https://api.fireworks.ai/inference/v1
JUDGE_TIMEOUT_SECONDS=
